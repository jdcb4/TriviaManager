# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trivia

# Auth
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
ADMIN_PASSWORD=change-this-to-a-strong-password

# AI (optional)
OPEN_ROUTER_API_KEY=

# Feature flags
FLAG_THRESHOLD=3   # BAD feedback votes before auto-flagging a question

# App
PORT=3000
NODE_ENV=development
